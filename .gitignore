# Rust
/target/

# Python
__pycache__/
*.pyc
.venv/
.pytest_cache/
.ruff_cache/
.mypy_cache/
*.egg-info/
dist/
build/
# Compiled extension built in-place by `maturin develop`.
anitomy-py/python/anitomy_ng/*.so
anitomy-py/python/anitomy_ng/*.pyd
anitomy-py/python/anitomy_ng/*.pdb

# Claude Code — machine-local settings only; shared .claude/settings.json is committed.
.claude/settings.local.json

# Generated by the benchmark workflow / scripts (CI artifacts, not committed)
/benchmark.md
/engines-config.json
/engine_*.json
/refs.md
/_ref/
/*-adapter
# Build output + lockfiles of the standalone crates under scripts/ (the
# benchmark/conformance adapters and the criterion bench crate). Each pins an
# upstream parser by branch, so the lock is regenerated per run, not committed.
scripts/**/target/
scripts/**/Cargo.lock

# npm / wasm build outputs
/dist-npm/
anitomy-js/pkg/
node_modules/

# C ABI: cbindgen-generated header, regenerated by anitomy-c/build.rs
anitomy-c/include/anitomy.h

# .NET / C# bindings build outputs
[Bb]in/
[Oo]bj/
*.nupkg
# Native libraries staged into the NuGet package by the build/CI
bindings/csharp/**/runtimes/

# Editors
.idea/
*.swp

# OS
.DS_Store
Thumbs.db
Desktop.ini
